# Optional overrides for docker-compose. No secrets are required — the whole
# pipeline is self-hosted (faster-whisper + local Ollama). Copy to .env only if
# you want to override the defaults.

# Grading model served by the host's Ollama. Recommend a real instruct model,
# e.g. qwen2.5:7b-instruct (pull it once: `ollama pull qwen2.5:7b-instruct`).
# Default is the tiny model that's already present.
OLLAMA_MODEL=qwen2.5:0.5b

# Whisper transcription. On the GPU server the defaults are cuda/float16/small;
# medium also fits alongside the 7B grader on an 8 GB card, but large-v3 + the 7B
# would exceed 8 GB VRAM. For a CPU-only host, set WHISPER_DEVICE=cpu (compute
# auto-falls back to int8).
WHISPER_MODEL=small
WHISPER_DEVICE=cuda
WHISPER_COMPUTE=float16

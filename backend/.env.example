# Copy to .env and fill in. .env is git-ignored. No secrets required — the eval
# runs on a local Ollama model, so there's no API key.

# Ollama endpoint. Local dev default; the container overrides this to
# http://host.docker.internal:11434 via docker-compose.
OLLAMA_HOST=http://localhost:11434

# Grading model (pull it in Ollama first). qwen2.5:0.5b is tiny/weak; prefer
# something like qwen2.5:7b-instruct for real feedback quality.
OLLAMA_MODEL=qwen2.5:0.5b

# Optional: whisper model size (tiny | base | small | medium | large-v3). Default: base
WHISPER_MODEL=base
